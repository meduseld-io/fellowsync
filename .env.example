SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-to-something-random

# Local development
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
FRONTEND_URL=http://localhost:5173

# Production (uncomment and set these for deployment)
# SPOTIFY_REDIRECT_URI=https://fellowsync.meduseld.io/callback
# FRONTEND_URL=https://fellowsync.meduseld.io

# BYOS Syncs — encryption key for storing Spotify client secrets at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Require BYOS syncs for public users (default: true)
# When true, non-admin users must create or join a sync before logging in
REQUIRE_BYOK=true
